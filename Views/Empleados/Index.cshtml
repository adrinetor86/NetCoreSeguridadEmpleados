@model List<Empleado>

<h1>Empleados</h1>


<table class="table table-striped">
    <thead>
    <tr>
        <th>Apellido</th>
        <th>Oficio</th>
        <th>Salario</th>
        <th>Departamento</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (Empleado emp in Model)
    {
        <tr>
            <td>@emp.Apellido</td>
            <td>@emp.Oficio</td>
            <td>@emp.Salario</td>
            <td>@emp.IdDepartamento</td>
            <td>
                <a class="nav-link text-dark" asp-area=""
                   asp-controller="Empleados"
                   asp-action="Details"
                   asp-route-id="@emp.IdEmpleado">
                    Detalles
                </a>
            </td>
        </tr>
    }
    </tbody>
</table>