@model Empleado


<table class="table table-striped">
    <thead>
    <tr>
        <th>Apellido</th>
        <th>Oficio</th>
        <th>Salario</th>
        <th>Departamento</th>
    </tr>
    </thead>
    <tbody>

        <tr>
            <td>@Model.Apellido</td>
            <td>@Model.Oficio</td>
            <td>@Model.Salario</td>
            <td>@Model.IdDepartamento</td>
        </tr>
    
    </tbody>
</table>